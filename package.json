{
  "name": "secret-notes",
  "version": "0.1.5",
  "description": "An Obsidian plugin for encrypting and previewing secret fenced code blocks.",
  "description_zh": "一个用于加密和预览 secret 代码块的 Obsidian 插件。",
  "scripts": {
    "check": "tsc --noEmit",
    "lint": "oxlint -c .oxlintrc.json . --tsconfig tsconfig.json",
    "lint:fix": "oxlint -c .oxlintrc.json . --tsconfig tsconfig.json --fix",
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "tag": "tsx scripts/tag.ts",
    "pub": "tsx scripts/pub.ts"
  },
  "author": {
    "name": "Kasukabe Tsumugi",
    "email": "futami16237@gmail.com"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "esbuild": "^0.25.4",
    "obsidian": "^1.12.3",
    "tslib": "^2.8.1",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3",
    "oxlint": "^1.72.0"
  },
  "dependencies": {}
}
